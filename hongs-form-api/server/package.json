{
  "name": "hongs-api-server",
  "version": "0.1.0",
  "description": "Hongs API Server - JSON-RPC 2.0 + MongoDB",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "node --watch --import tsx src/server.ts",
    "build": "tsc && powershell -Command \"New-Item -ItemType Directory -Path 'dist/api/mcp/scopes/agent/prompts' -Force; Copy-Item -Path src/api/mcp/scopes/agent/prompts/*.md -Destination dist/api/mcp/scopes/agent/prompts/ -Force\"",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit",
    "seed": "tsx scripts/seed.ts",
    "cleanup-roster": "tsx scripts/cleanup-roster.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "mongodb": "^6.3.0",
    "hongs-form": "file:../../hongs-form",
    "hongs-captcha": "file:../../hongs-captcha"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "Hongs",
  "license": "MIT"
}

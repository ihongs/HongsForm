{
  "name": "hongs-api-server",
  "version": "0.1.0",
  "description": "Hongs API Server - JSON-RPC 2.0 + MongoDB",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "node --watch --import tsx src/server.ts",
    "lint": "tsc --noEmit",
    "build": "tsc",
    "start": "node dist/server.js",
    "clean": "node dist/scripts/clean.js",
    "dev:clean": "tsx src/scripts/clean.ts",
    "dev:test-seed": "tsx src/scripts/test-init.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "hongs-form": "^0.1.6",
    "mongodb": "^6.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": "Hongs",
  "license": "MIT"
}
